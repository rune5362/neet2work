# Common
NODE_ENV=development

# Frontend
VITE_API_BASE_URL=http://localhost:3000

# Backend
PORT=3000
CLIENT_URL=http://localhost:5173

# AI
AI_API_KEY=
AI_MODEL=

# Database - Optional
# 각자 개인 개발 DB의 PostgreSQL URL을 사용합니다.
# 예: Supabase, AWS RDS, 로컬 PostgreSQL, Docker PostgreSQL
# 읽기 쉽게 관리하려면 DATABASE_URL에는 비밀번호를 빼고 DATABASE_PASSWORD에만 둡니다.
DATABASE_URL=
DATABASE_PASSWORD=
POSTGRES_USER=neet2work
POSTGRES_PASSWORD=neet2work
POSTGRES_DB=neet2work

# AWS RDS - Optional
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Cloudflare R2 - Optional
R2_ENDPOINT=
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Oracle Cloud - Optional
ORACLE_CLOUD_REGION=
ORACLE_CLOUD_CONFIG_PATH=

# Figma - Optional
FIGMA_ACCESS_TOKEN=
FIGMA_FILE_KEY=
FIGMA_TARGET_NODE_ID=
FIGMA_TARGET_TEXT_LAYER_NAME=

{
  "name": "@neet2work/backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "prisma generate && tsc",
    "start": "node dist/server.js",
    "lint": "eslint src",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:create": "prisma migrate dev --create-only",
    "db:deploy": "prisma migrate deploy",
    "db:reset": "prisma migrate reset",
    "db:seed": "prisma db seed",
    "db:import:jobs": "tsx prisma/importJobPostings.ts",
    "db:lifecycle:jobs:dry-run": "tsx src/scripts/jobLifecycleDryRun.ts",
    "db:lifecycle:jobs:apply": "tsx src/scripts/jobLifecycleApply.ts",
    "jobs:operational:plan": "tsx src/scripts/jobOperationalPipeline.ts",
    "jobs:operational:manual-run": "tsx src/scripts/jobOperationalManualRun.ts",
    "jobs:operational:sql-artifacts": "tsx src/scripts/jobOperationalSqlArtifacts.ts",
    "jobs:operational:scheduler": "tsx src/scripts/jobOperationalScheduler.ts",
    "jobs:operational:jp-plan": "tsx src/scripts/jobOperationalJpPlan.ts",
    "db:studio": "prisma studio",
    "db:status": "prisma migrate status"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.0.0",
    "@prisma/client": "^7.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "^5.0.0",
    "pg": "^8.0.0",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.0",
    "@types/express": "^5.0.0",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.0.0",
    "playwright": "^1.0.0",
    "prisma": "^7.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0"
  }
}

:root {
  color: #19221d;
  background: #f4efe3;
  font-family:
    "Pretendard",
    "Apple SD Gothic Neo",
    "Malgun Gothic",
    sans-serif;
}

* {
  box-sizing: border-box;
}

body {
  margin: 0;
  min-width: 320px;
  min-height: 100vh;
  background:
    radial-gradient(circle at top left, rgba(255, 196, 87, 0.42), transparent 34rem),
    linear-gradient(135deg, #fbf5e8 0%, #e9f0dd 52%, #dfead9 100%);
}

button,
textarea {
  font: inherit;
}

.shell {
  width: min(1180px, calc(100% - 32px));
  margin: 0 auto;
  padding: 48px 0;
}

.hero,
.workspace,
.resultPanel {
  display: grid;
  gap: 24px;
}

.hero {
  grid-template-columns: minmax(0, 1fr) 320px;
  align-items: end;
  margin-bottom: 28px;
}

.eyebrow,
.sectionTitle p,
.heroCard span,
.scoreBox span {
  margin: 0;
  color: #5a704a;
  font-size: 0.78rem;
  font-weight: 800;
  letter-spacing: 0.12em;
  text-transform: uppercase;
}

h1,
h2,
h3,
p {
  margin-top: 0;
}

h1 {
  margin-bottom: 16px;
  font-size: clamp(3rem, 8vw, 6.8rem);
  line-height: 0.9;
  letter-spacing: -0.08em;
}

.heroText {
  max-width: 720px;
  margin-bottom: 0;
  color: #3f4d41;
  font-size: 1.1rem;
  line-height: 1.8;
}

.heroCard,
.panel,
.resultPanel {
  border: 1px solid rgba(37, 52, 36, 0.12);
  border-radius: 28px;
  background: rgba(255, 252, 245, 0.78);
  box-shadow: 0 24px 70px rgba(47, 58, 41, 0.12);
  backdrop-filter: blur(18px);
}

.heroCard {
  padding: 24px;
}

.heroCard strong {
  display: block;
  margin: 10px 0;
  font-size: 1.5rem;
}

.heroCard p,
.muted {
  margin-bottom: 0;
  color: #697568;
  line-height: 1.7;
}

.alert {
  margin-bottom: 20px;
  border: 1px solid #f2a37f;
  border-radius: 18px;
  padding: 14px 18px;
  background: #fff0e7;
  color: #a1431b;
}

.workspace {
  grid-template-columns: 1.05fr 0.95fr;
  align-items: start;
}

.panel,
.resultPanel {
  padding: 26px;
}

.sectionTitle {
  margin-bottom: 18px;
}

.sectionTitle h2 {
  margin-bottom: 0;
  font-size: 1.7rem;
}

.jobList {
  display: grid;
  gap: 14px;
}

.jobCard {
  width: 100%;
  border: 1px solid rgba(25, 34, 29, 0.1);
  border-radius: 22px;
  padding: 20px;
  background: #fffdf6;
  color: inherit;
  text-align: left;
  cursor: pointer;
  transition:
    transform 180ms ease,
    border-color 180ms ease,
    box-shadow 180ms ease;
}

.jobCard:hover,
.jobCard.selected {
  transform: translateY(-2px);
  border-color: #5b7f40;
  box-shadow: 0 16px 36px rgba(62, 87, 45, 0.14);
}

.jobCard span {
  color: #5a704a;
  font-weight: 700;
}

.jobCard strong {
  display: block;
  margin: 8px 0;
  font-size: 1.25rem;
}

.jobCard p {
  margin-bottom: 14px;
  color: #687366;
}

.chips {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.chips em {
  border-radius: 999px;
  padding: 6px 10px;
  background: #e9f0dd;
  color: #415a32;
  font-size: 0.78rem;
  font-style: normal;
  font-weight: 700;
}

textarea {
  width: 100%;
  min-height: 280px;
  resize: vertical;
  border: 1px solid rgba(25, 34, 29, 0.12);
  border-radius: 22px;
  padding: 18px;
  background: #fffdf6;
  color: #28352b;
  line-height: 1.7;
}

textarea:focus {
  outline: 3px solid rgba(91, 127, 64, 0.2);
  border-color: #5b7f40;
}

.panel > button {
  width: 100%;
  margin-top: 16px;
  border: 0;
  border-radius: 18px;
  padding: 16px 20px;
  background: #19221d;
  color: #fff8eb;
  font-weight: 800;
  cursor: pointer;
}

.panel > button:disabled {
  cursor: wait;
  opacity: 0.72;
}

.resultPanel {
  grid-template-columns: 220px repeat(2, minmax(0, 1fr));
  margin-top: 24px;
}

.resultPanel.empty {
  display: block;
  color: #697568;
}

.scoreBox {
  display: grid;
  align-content: center;
  border-radius: 24px;
  padding: 24px;
  background: #19221d;
  color: #fff8eb;
}

.scoreBox span {
  color: #ffcf72;
}

.scoreBox strong {
  font-size: 4rem;
  line-height: 1;
}

.scoreBox p {
  margin-bottom: 0;
  color: #dbe5d3;
}

.resultList {
  border-top: 1px solid rgba(25, 34, 29, 0.1);
  padding-top: 16px;
}

.resultList h3 {
  margin-bottom: 10px;
}

.resultList ul {
  margin: 0;
  padding-left: 20px;
  color: #3f4d41;
  line-height: 1.7;
}

@media (max-width: 860px) {
  .shell {
    padding: 32px 0;
  }

  .hero,
  .workspace,
  .resultPanel {
    grid-template-columns: 1fr;
  }
}

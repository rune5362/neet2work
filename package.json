{
  "name": "neet2work",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@11.1.1+sha512.d1fdf5f73c617b64fa1a56a81c3c8dfe0e966e33a6010aa256b517ae77be21d93e05affc0de1a83b0e4f29d569f68b446ae8f068cd7247c0bb3df0fb4d7bdf9a",
  "scripts": {
    "setup": "corepack pnpm install && corepack pnpm run setup:env && corepack pnpm run db:generate && corepack pnpm run setup:playwright",
    "setup:windows": "powershell -ExecutionPolicy Bypass -File scripts/setup-windows.ps1",
    "setup:unix": "bash scripts/setup-unix.sh",
    "setup:vscode": "powershell -ExecutionPolicy Bypass -File scripts/install-vscode-extensions.ps1",
    "setup:env": "node scripts/setup-env.mjs",
    "setup:playwright": "corepack pnpm --filter @neet2work/backend exec playwright install chromium",
    "db:generate": "corepack pnpm --filter @neet2work/backend run db:generate",
    "db:migrate": "corepack pnpm --filter @neet2work/backend run db:migrate",
    "db:migrate:create": "corepack pnpm --filter @neet2work/backend run db:migrate:create",
    "db:deploy": "corepack pnpm --filter @neet2work/backend run db:deploy",
    "db:reset": "corepack pnpm --filter @neet2work/backend run db:reset",
    "db:seed": "corepack pnpm --filter @neet2work/backend run db:seed",
    "db:import:jobs": "corepack pnpm --filter @neet2work/backend run db:import:jobs",
    "db:studio": "corepack pnpm --filter @neet2work/backend run db:studio",
    "db:status": "corepack pnpm --filter @neet2work/backend run db:status",
    "crawl:saramin:check": "corepack pnpm --filter @neet2work/backend exec tsx src/scripts/saraminImportCheck.ts",
    "dev": "concurrently \"corepack pnpm --filter @neet2work/backend dev\" \"corepack pnpm --filter @neet2work/frontend dev\"",
    "dev:frontend": "corepack pnpm --filter @neet2work/frontend dev",
    "dev:backend": "corepack pnpm --filter @neet2work/backend dev",
    "build": "corepack pnpm --filter @neet2work/frontend build && corepack pnpm --filter @neet2work/backend build",
    "lint": "corepack pnpm --filter @neet2work/frontend lint && corepack pnpm --filter @neet2work/backend lint",
    "test": "corepack pnpm --filter @neet2work/frontend test && corepack pnpm --filter @neet2work/backend test",
    "check": "corepack pnpm run lint && corepack pnpm run test && corepack pnpm run build",
    "security:audit": "corepack pnpm audit --recursive",
    "docker:up": "docker compose up --build",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "concurrently": "^9.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "typescript-eslint": "^8.0.0"
  },
  "engines": {
    "node": ">=24.14.0 <25"
  }
}

{
  "name": "ilhad-eum-youth",
  "version": "1.0.0",
  "private": true,
  "packageManager": "npm@11.6.2",
  "workspaces": [
    "apps/frontend",
    "apps/backend"
  ],
  "scripts": {
    "figma:check": "node scripts/check-figma-target.mjs",
    "worklog:prepare": "node scripts/prepare-work-log-day.mjs",
    "worklog:export": "node scripts/prepare-work-log-day.mjs --quiet && node scripts/export-work-log.mjs",
    "figma:bridge": "node scripts/prepare-work-log-day.mjs --quiet && node scripts/serve-figma-work-log.mjs",
    "figma:apply-log": "node scripts/prepare-work-log-day.mjs --quiet && node scripts/apply-figma-work-log.mjs",
    "figma:serve-log": "node scripts/serve-figma-work-log.mjs",
    "dev": "concurrently \"npm run dev -w apps/backend\" \"npm run dev -w apps/frontend\"",
    "dev:frontend": "npm run dev -w apps/frontend",
    "dev:backend": "npm run dev -w apps/backend",
    "build": "npm run build -w apps/frontend && npm run build -w apps/backend",
    "lint": "npm run lint -w apps/frontend && npm run lint -w apps/backend",
    "test": "npm run test -w apps/frontend && npm run test -w apps/backend",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "concurrently": "^9.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "typescript-eslint": "^8.0.0"
  },
  "engines": {
    "node": ">=24"
  }
}
